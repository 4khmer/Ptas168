{
  "name": "@ptas/sdk",
  "version": "0.0.0",
  "private": true,
  "description": "PTAS168 backend SDK — typed HTTP client + per-domain API wrappers + wire/UI adapters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ptas/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
