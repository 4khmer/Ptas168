{
  "name": "@ptas/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types and Zod schemas for the PTAS168 monorepo (DTOs, enums, error envelope). No logic, no Prisma, no framework imports.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
