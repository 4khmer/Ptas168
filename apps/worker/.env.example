NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptas168_dev"
REDIS_URL="redis://localhost:6379"
LOG_LEVEL=debug

# Cron expression for the daily overdue-invoice check.
# Default fires at 09:00 every day. Set to '*/5 * * * *' to fire every
# 5 minutes for development.
OVERDUE_CRON="0 9 * * *"
