NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptas168_dev"
REDIS_URL="redis://localhost:6379"
JWT_SECRET=dev_jwt_secret_change_me_minimum_32_characters_long
JWT_EXPIRES_IN=24h
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:8080
# ── File uploads ──────────────────────────────────────────────────────────
# Two backends supported:
#   1. Cloudflare R2  (set R2_BUCKET + R2_PUBLIC_URL + creds below)
#   2. Local disk     (default — uses UPLOAD_DIR; serves via /uploads
#                       in dev via express.static)
# The backend picks R2 automatically when R2_BUCKET is set.
#
# Disk-mode defaults (used when R2 is not configured):
UPLOAD_DIR=./uploads
FILE_URL_BASE=http://localhost:3001/uploads

# ── Cloudflare R2 (optional) ──────────────────────────────────────────────
# How to wire this from scratch:
#   1. cloudflare dashboard → R2 → Create bucket          (e.g. "ptas168")
#   2. R2 → Manage API Tokens → Create API token,
#      permission "Object Read & Write", scope to the bucket.
#      The token shows Access Key ID + Secret Access Key once — copy both.
#   3. R2_ACCOUNT_ID is shown in the R2 sidebar; or on Workers & Pages →
#      Account ID. It's a 32-char hex string.
#   4. In the bucket settings, either:
#        a) toggle "Public Access" → use the auto `https://pub-<hash>.r2.dev`,
#           OR
#        b) add a custom domain (e.g. files.4khmerapp.xyz) for branded URLs.
#      Use whichever URL the bucket gave you as R2_PUBLIC_URL (no trailing /).
# Leave all R2_* blank to keep using local disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Mount prefix for the Express routes. Default '/api'. Override when a
# reverse proxy forwards a sub-path without stripping it (e.g. /ptas168/api).
API_BASE_PATH=/api
