NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptas168_dev"
REDIS_URL="redis://localhost:6379"
JWT_SECRET=dev_jwt_secret_change_me_minimum_32_characters_long
JWT_EXPIRES_IN=24h
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:8080
# File uploads
# Local dev defaults — backend creates ./uploads if missing and serves
# them at /uploads via express.static. In production both vars are set
# to the Tomcat-served path:
#   UPLOAD_DIR=/usr/local/Cellar/tomcat@10/10.1.52/libexec/webapps/ROOT/ptas168_file
#   FILE_URL_BASE=https://4khmerapp.xyz/ptas168_file
UPLOAD_DIR=./uploads
FILE_URL_BASE=http://localhost:3001/uploads
# Mount prefix for the Express routes. Default '/api'. Override when a
# reverse proxy forwards a sub-path without stripping it (e.g. /ptas168/api).
API_BASE_PATH=/api
