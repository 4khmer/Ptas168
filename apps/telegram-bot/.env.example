NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptas168_dev"
REDIS_URL="redis://localhost:6379"
LOG_LEVEL=debug

# Telegram bot token from @BotFather. Without this, the bot stays in
# "stub" mode: BullMQ consumers run, but no Telegram polling happens.
# This is convenient for local testing without a real bot.
TELEGRAM_BOT_TOKEN=
