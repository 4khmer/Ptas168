{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    // Migration is complete — apps/frontend/src is 100% TypeScript.
    // allowJs / checkJs removed so any stray .js or .jsx slipping back
    // into src/ becomes a hard error instead of silently bypassing tsc.

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,

    // Vite owns the emit. TS is type-check-only here.
    "noEmit": true,

    // Lets us import .json (e.g. translation files in lib/i18n) by Vite's loader.
    "allowSyntheticDefaultImports": true
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
