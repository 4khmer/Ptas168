{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    // Mixed JS + TS during migration. Existing .js files keep working;
    // new .ts/.tsx files get full type-checking. Flip checkJs to true
    // (or remove allowJs entirely) once the migration is complete.
    "allowJs": true,
    "checkJs": false,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,

    // Vite owns the emit. TS is type-check-only here.
    "noEmit": true,

    // Lets us import .json (e.g. translation files in lib/i18n) by Vite's loader.
    "allowSyntheticDefaultImports": true
  },
  "include": ["src", "vite.config.js", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
