# Backend origin (no trailing slash).
# Used by Vite's dev proxy — not exposed to the browser bundle.
# Copy this file to .env.local and set the correct port.
BACKEND_URL=http://localhost:3001

# Base URL the frontend bundle uses for API calls.
# Browser hits this absolute URL; the reverse proxy in front of Express
# forwards /ptas168/api/* to 127.0.0.1:3001 and the backend mounts its
# routes at /ptas168/api (set via API_BASE_PATH in the backend env).
VITE_API_URL=https://4khmerapp.xyz/ptas168/api

# Base URL where Tomcat serves the uploaded-file directory.
# In production this is https://4khmerapp.xyz/ptas168_file
VITE_FILE_URL=https://4khmerapp.xyz/ptas168_file
