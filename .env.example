# Compose-level env file. Copy this to `.env` (which is gitignored) and
# fill in the secrets you actually want to use.
#
# docker compose --env-file .env reads this file and substitutes ${VAR}
# references in infrastructure/docker/docker-compose.yml. All `pnpm
# compose:*` and `pnpm db:*` scripts pass --env-file .env automatically.
#
# Each var has a sensible default in the compose file (${VAR:-default}),
# so any var you leave commented out keeps its default behavior.

# ── Cloudflare R2 (file uploads) ──────────────────────────────────────────
# When R2_BUCKET + R2_PUBLIC_URL are set, the backend stores uploads in R2
# and returns the public URL. Leave blank to use the bundled disk fallback.
# See apps/backend/.env.example for the full R2 setup walkthrough.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ── Backend secrets ───────────────────────────────────────────────────────
# Override the dev defaults when running compose for anything beyond local
# testing. JWT_SECRET must be ≥ 32 chars.
# JWT_SECRET=
# JWT_EXPIRES_IN=24h
# CORS_ORIGIN=http://localhost:8080

# ── Telegram (apps/telegram-bot) ──────────────────────────────────────────
# Leave blank to keep the bot in stub mode (queue consumer runs, grammY
# polling is disabled). Set when you want to send real Telegram messages.
# TELEGRAM_BOT_TOKEN=

# ── Misc ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# OVERDUE_CRON=0 9 * * *
